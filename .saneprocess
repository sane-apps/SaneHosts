# SaneProcess compliance manifest
name: SaneHosts
type: macos_app
scheme: SaneHosts
project: SaneHosts.xcodeproj
bundle_id: com.mrsane.SaneHosts

build:
  workspace: SaneHosts.xcworkspace

tests:
  unit_target: SaneHostsFeatureTests
  ui_target: SaneHostsUITests
  use_test_plan: true
  disable_due_to_swiftuicore_linker_bug: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.sanehosts.com
  site_host: sanehosts.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"
  upgrade_path_test:
    scheme: SaneHosts
    test_plan: SaneHosts
    test_selector: SaneHostsFeatureTests/ProfileStoreEssentialsPolicyTests/createsEssentialsAlongsideExistingEntries
    from_version: "1.1.22"
    timeout_seconds: 300
  reviewed_auto_reconcile_stashes:
    - stash_sha: "d92b0baac8c8a7aac77cf19143745c00089bf0d3"
      subject: "On main: auto-reconcile-20260509-055518-stephans-mac-mini"
      decision: recovered
      reason: "Reviewed 2026-05-09. The 1.1.10 version/category bump and first-launch prompt scheduling are already in HEAD, and live direct release/docs are at 1.1.11."
    - stash_sha: "fbb3637203cbf78e3cf4cb9621524a21ac25b66a"
      subject: "On main: auto-reconcile-20260508-215519-stephans-mac-mini"
      decision: recovered
      reason: "Reviewed 2026-05-09. Settings/About/License/update routing, move-to-Applications support, and navigation work are already represented in HEAD; the remaining SaneHostsApp delta is an older pre-1.1.11 variant that lacks the current first-launch prompt path."
    - stash_sha: "87db0dd486250a16263695cbb25c662abb050389"
      subject: "On main: auto-reconcile-20260505-215526-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. .outreach.yml bookkeeping only (Gas Mask response history). Not release-facing code or customer docs."
    - stash_sha: "8eeb7943c30509bd0cff5d5b8452531a2ecfcc6c"
      subject: "On main: auto-reconcile-20260425-215520-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. Privacy-policy and handoff wording were revised again for the May 5, 2026 release; current HEAD and live privacy docs are newer than this stash."
    - stash_sha: "2a4cc1702b50eae09ef20beb9878d780621204d1"
      subject: "On main: auto-reconcile-20260424-153452-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. CLAUDE.md overlay/tooling guidance only. No shipped app behavior, release metadata, or public docs depend on it."
    - stash_sha: "1ab7b52b1d75e3ab6a71628a436bf52c705add61"
      subject: "On main: auto-reconcile-20260416-055517-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. .claude/research.md scratch research only. Not a release artifact."
    - stash_sha: "c2ae767fe2e9c6771bfd47a5e872ee212c81e694"
      subject: "On main: auto-reconcile-20260415-215519-stephans-mac-mini"
      decision: recovered
      reason: "Reviewed 2026-05-09. The 1.1.8 pricing/release-note content is already captured in CHANGELOG and later releases; README/live docs have moved on to 1.1.11."
    - stash_sha: "62d9ab9472ff33b4f6a2f4629976b70e2c4e09df"
      subject: "On main: auto-reconcile-20260415-055522-stephans-mac-mini"
      decision: recovered
      reason: "Reviewed 2026-05-09. The direct-download-only posture, $14.99 pricing, App Store disablement, and website copy all landed; live site now advertises 1.1.11 and $14.99, so this stash is an older release snapshot."
    - stash_sha: "26c1cf88446f58c97f7bce0acea10fbd53154ea0"
      subject: "On main: auto-reconcile-20260508-215529-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09. DirectDistributionSupport, SettingsView, navigation tests, and app-entry refactor are represented in the current release candidate; the current SaneHostsApp.swift first-launch prompt is the intended worktree variant to keep."
    - stash_sha: "6295dd31dac2fbc46f5c0655213ffb71aabb58af"
      subject: "On main: auto-reconcile-20260501-215526-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. Analytics-only first_value_action collateral is not required for this direct release."
    - stash_sha: "6262f1180895906b80bf7a2fda03a195b01cb724"
      subject: "On main: auto-reconcile-20260429-215525-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Locked duplicate UI and current navigation behavior are already present in the current tree; older cleanup/test deltas are superseded."
    - stash_sha: "e328725740f3704dcb84631b08a0286d590ed3eb"
      subject: "On main: auto-reconcile-20260425-215529-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Docs/site/admin drift only, not runtime release work."
    - stash_sha: "58af548b0b778c8bdc8a81c68b675609f97237b2"
      subject: "On main: auto-reconcile-20260424-153503-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Docs/site/admin drift only, not runtime release work."
    - stash_sha: "4bfa6e70c970a8c316b1a06a772040e7914171b0"
      subject: "On main: auto-reconcile-20260418-055526-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Docs/site/admin drift only, not runtime release work."
    - stash_sha: "468f4214353f9233cbe5757900cc2dd2e6f69f6e"
      subject: "On main: auto-reconcile-20260413-215540-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Config/admin drift superseded by current SaneProcess policy."
    - stash_sha: "ada3c5113eef2e922873ada9d82d506e26a9d731"
      subject: "On main: auto-reconcile-20260411-055525-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Config/admin drift superseded by current SaneProcess policy."
    - stash_sha: "cf2f9905ddaf9ffc0f6e330604b44668882a845f"
      subject: "On main: auto-reconcile-20260410-215527-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Config/admin drift superseded by current SaneProcess policy."
  verify_staple: true
  version_bump_cmd: "sed -i '' \"s/^MARKETING_VERSION = .*/MARKETING_VERSION = ${version}/\" Config/Shared.xcconfig && sed -i '' \"s/^CURRENT_PROJECT_VERSION = .*/CURRENT_PROJECT_VERSION = ${project_version}/\" Config/Shared.xcconfig"
  version_bump_restore_cmd: "git -C ${PROJECT_ROOT} restore --staged --worktree Config/Shared.xcconfig 2>/dev/null || git -C ${PROJECT_ROOT} checkout -- Config/Shared.xcconfig 2>/dev/null || true"
  version_bump_files:
    - Config/Shared.xcconfig
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "600 428"
    app_icon_pos: "150 190"
    drop_pos: "450 190"
    no_internet_enable: true
  archive_extra_args:
    - DEVELOPMENT_TEAM=M78L6FXD48
    - "CODE_SIGN_IDENTITY=Developer ID Application"
    - CODE_SIGN_STYLE=Manual
  export:
    profiles:
      - "com.mrsane.SaneHosts:com.mrsane.SaneHosts Direct"

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: false
  # Current strategy: direct-download only.
  # Do not route the current SaneHosts architecture through App Store release automation.
  # The app's privileged helper / launchd daemon model is not Mac-App-Store-safe.
  app_id: "6759330900"
  product_id: "com.sanehosts.app.pro.unlock"
  configuration: Release
  platforms: [macos]
  category: public.app-category.utilities
  age_rating: "4+"
  privacy_policy_url: "https://sanehosts.com/privacy"
  support_url: "https://sanehosts.com/support"
  marketing_url: "https://sanehosts.com"
  metadata:
    macos:
      subtitle: "Block Ads System-Wide"
      promotional_text: "Activate a cleaner hosts file in one click. Block ads, trackers, malware, and distractions with simple profiles and local control."
      description: >-
        SaneHosts helps you block ads, trackers, malware, and distracting sites across your Mac by managing your hosts file with clear local-first profiles.
        Start with the built-in Essentials profile, activate protection in one click, and inspect or customize entries when you want more control.
        Advanced tools let you import blocklists, merge sources, and build custom profiles while keeping everything on-device.
      keywords: "hosts file,ad blocker,tracker blocker,malware,website blocker,privacy,focus,mac utility"
      whats_new: "Improved onboarding, clearer feature gating, and stronger activation reliability."
      marketing_url: "https://sanehosts.com"
  review_notes: "SaneHosts is direct-download only in the current product strategy. The current helper and launchd daemon architecture is not Mac-App-Store-safe, so this repo state should not be submitted as an App Store build. If an App Store-safe redesign happens later, rework reviewer guidance, entitlements, and monetization notes from scratch."
  review_notes_by_platform:
    macos: "SaneHosts is direct-download only in the current product strategy. The current helper and launchd daemon architecture is not Mac-App-Store-safe, so this repo state should not be submitted as an App Store build. If an App Store-safe redesign happens later, rework reviewer guidance, entitlements, and monetization notes from scratch."
  screenshots:
    macos: marketing/appstore-images/*.png
  build_flags:
    - APPSTORE_PRODUCT_ID=com.sanehosts.app.pro.unlock
    - 'OTHER_SWIFT_FLAGS=$(inherited) -D APP_STORE'
    - CODE_SIGN_ENTITLEMENTS=Config/SaneHosts-AppStore.entitlements
    - CODE_SIGN_STYLE=automatic
    - INFOPLIST_FILE=SaneHosts/Info-AppStore.plist
    - INFOPLIST_KEY_LSApplicationCategoryType=public.app-category.utilities
    - 'INFOPLIST_KEY_SUFeedURL='
    - 'INFOPLIST_KEY_SUEnableAutomaticChecks='
    - 'INFOPLIST_KEY_SUPublicEDKey='
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: sanehosts.com
