// Shared.xcconfig
// Minimal shared configuration for scaffold tool customization
// All other settings use Xcode project defaults
// Generated by Xcode

// ==========================================
// Project Identity
// ==========================================
PRODUCT_NAME = SaneHosts
PRODUCT_DISPLAY_NAME = SaneHosts
PRODUCT_BUNDLE_IDENTIFIER = com.mrsane.SaneHosts
MARKETING_VERSION = 1.1.20
CURRENT_PROJECT_VERSION = 1120

// ==========================================
// Platform Configuration
// ==========================================
MACOSX_DEPLOYMENT_TARGET = 14.0
ALWAYS_SEARCH_USER_PATHS = NO

// ==========================================
// Info PLIST
// ==========================================
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_FILE = SaneHosts/Info.plist
INFOPLIST_KEY_LSUIElement = YES
INFOPLIST_KEY_LSApplicationCategoryType = public.app-category.utilities
APPSTORE_PRODUCT_ID =

// ==========================================
// Code Signing & Security
// ==========================================
// AI agents can modify Config/SaneHosts.entitlements to add capabilities
CODE_SIGN_ENTITLEMENTS = Config/SaneHosts.entitlements
ENABLE_HARDENED_RUNTIME = YES

// Manual Developer ID signing for the app target. The keychain-access-groups
// entitlement is "restricted" and must be authorized by a provisioning profile
// (TN3137), so automatic signing fails ("requires a provisioning profile").
// The "com.mrsane.SaneHosts Direct" Developer ID profile carries the team
// wildcard M78L6FXD48.* which authorizes M78L6FXD48.com.mrsane.SaneHosts.
// (Helper target uses Helper.xcconfig and stays Automatic — no entitlement.)
CODE_SIGN_STYLE = Manual
DEVELOPMENT_TEAM = M78L6FXD48
CODE_SIGN_IDENTITY = Developer ID Application
PROVISIONING_PROFILE_SPECIFIER = com.mrsane.SaneHosts Direct

// ==========================================
// Excluded Resources
// ==========================================
// Prevent CLAUDE.md files (auto-generated by hooks) from being copied into the app bundle
EXCLUDED_SOURCE_FILE_NAMES = $(inherited) CLAUDE.md

// ==========================================
// Framework Search Paths
// ==========================================
LD_RUNPATH_SEARCH_PATHS = $(inherited) @executable_path/../Frameworks

// ==========================================
// App Icon
// ==========================================
// Manual icns file - CFBundleIconFile added via Info.plist generation
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
INFOPLIST_KEY_CFBundleIconFile = AppIcon

// ==========================================
// Sparkle Auto-Updates
// ==========================================
INFOPLIST_KEY_SUFeedURL = https:/$()/sanehosts.com/appcast.xml
INFOPLIST_KEY_SUEnableAutomaticChecks = YES
INFOPLIST_KEY_SUPublicEDKey = 7Pl/8cwfb2vm4Dm65AByslkMCScLJ9tbGlwGGx81qYU=
