    "sanehosts.settings.startup.dock_icon_hint" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn du das Dock-Symbol ausblendest, bleibt SaneHosts weiterhin über die Menüleiste verfügbar." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If you hide the Dock icon, SaneHosts stays available from the menu bar." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Si ocultas el ícono del Dock, SaneHosts seguirá disponible desde la barra de menús." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Si vous masquez l’icône du Dock, SaneHosts reste disponible depuis la barre des menus." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Se nascondi l'icona nel Dock, SaneHosts resta disponibile dalla barra dei menu." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Dockアイコンを非表示にしても、SaneHostsはメニューバーから使えます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Dock 아이콘을 숨겨도 SaneHosts는 메뉴 막대에서 계속 사용할 수 있습니다." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Als je het Dock-pictogram verbergt, blijft SaneHosts beschikbaar via de menubalk." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Se você ocultar o ícone do Dock, o SaneHosts continua disponível na barra de menus." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果隐藏 Dock 图标，SaneHosts 仍可从菜单栏打开。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "如果隱藏 Dock 圖示，仍可從選單列使用 SaneHosts。" } }
      }
    },
